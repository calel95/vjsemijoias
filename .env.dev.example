APP_ENV=development
DEBUG=false
PORT=5000

# Use Postgres/Neon/Render Postgres for DEV deploys.
# Do not use the local SQLite file outside your computer.
DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require&channel_binding=require

SECRET_KEY=gere-uma-chave-longa-para-dev
JWT_SECRET_KEY=gere-outra-chave-longa-para-dev
ADMIN_PASSWORD=troque-esta-senha-dev
ADMIN_TOKEN_EXPIRE_MINUTES=120
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_SECONDS=300

PUBLIC_BASE_URL=https://seu-servico-dev.onrender.com
CORS_ALLOWED_ORIGINS=https://seu-servico-dev.onrender.com
INFINITEPAY_HANDLE=sua_infinite_tag
INFINITEPAY_API_BASE=https://api.checkout.infinitepay.io

# Storage de imagens do catalogo em DEV.
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=seu_account_id_cloudflare
R2_BUCKET=vjsemijoias-dev
R2_ACCESS_KEY_ID=sua_access_key_id
R2_SECRET_ACCESS_KEY=sua_secret_access_key
R2_PUBLIC_BASE_URL=https://seu-bucket-publico.r2.dev

STORE_NAME=VJ Semijoias DEV
STORE_SHORT_NAME=VJ DEV
STORE_TAGLINE=SEMIJOIAS
STORE_DESCRIPTION=Ambiente DEV para testes da loja.
STORE_SLOGAN=Brilhe em cada momento
STORE_LOGO_PATH=images/logo.png
STORE_EMAIL=contato@vjsemijoias.com
STORE_PHONE=(51) 98211-0842
STORE_WHATSAPP=51 982110842
STORE_INSTAGRAM=vj_semijoias
STORE_WEBSITE=www.vjsemijoias.com
STORE_CNPJ=
STORE_CATALOG_TITLE=CATALOGO VJ SEMIJOIAS
STORE_CATALOG_COLLECTION=Colecao Banhada a Ouro 18k
STORE_CATALOG_FILENAME=catalogo-vj-semijoias.pdf

SHIPPING_MODE=free
SHIPPING_FIXED_VALUE=0
SHIPPING_FREE_MINIMUM=0
SHIPPING_ESTIMATED_DAYS=5-10

COUPONS_ENABLED=true
COUPON_CODE=VJ10
COUPON_DISCOUNT_PERCENT=10
COUPON_USAGE_LIMIT=100
