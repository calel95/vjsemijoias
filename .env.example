SECRET_KEY=troque-esta-chave
JWT_SECRET_KEY=troque-esta-chave-jwt
ADMIN_PASSWORD=troque-esta-senha
ADMIN_TOKEN_EXPIRE_MINUTES=120
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_SECONDS=300
ADMIN_COOKIE_NAME=vj_admin_token
ADMIN_COOKIE_SECURE=true
ADMIN_COOKIE_SAMESITE=lax
USER_TOKEN_EXPIRE_DAYS=7
USER_COOKIE_NAME=vj_user_token
USER_COOKIE_SECURE=true
USER_COOKIE_SAMESITE=lax
CSRF_COOKIE_SECURE=true
# Local:
# DATABASE_URL=sqlite:///vjsemijoias.db
# Producao/PostgreSQL Neon:
# DATABASE_URL=postgresql://usuario:senha@host/neondb?sslmode=require&channel_binding=require
DATABASE_URL=sqlite:///vjsemijoias.db
PORT=5000
DEBUG=false
INFINITEPAY_HANDLE=sua_infinite_tag
PUBLIC_BASE_URL=https://seu-dominio.com
# INFINITEPAY_API_BASE=https://api.checkout.infinitepay.io

# E-mails transacionais:
# console = registra/loga sem enviar; smtp = envia por servidor SMTP; disabled = desliga.
EMAIL_BACKEND=console
EMAIL_FROM_NAME=VJ Semijoias
EMAIL_FROM_ADDRESS=nao-responda@seu-dominio.com
# EMAIL_SMTP_HOST=smtp.seu-provedor.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USERNAME=usuario
# EMAIL_SMTP_PASSWORD=senha
# EMAIL_SMTP_USE_TLS=true

# Rate limiting por IP para rotas /api.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_PER_MINUTE=300
RATE_LIMIT_PUBLIC_PER_MINUTE=180
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_REGISTER_PER_HOUR=5
RATE_LIMIT_WRITE_PER_MINUTE=60
RATE_LIMIT_EXPENSIVE_PER_MINUTE=5

# Configuracoes da loja:
STORE_NAME=VJ Semijoias
STORE_SHORT_NAME=VJ
STORE_TAGLINE=SEMIJOIAS
STORE_DESCRIPTION=Semijoias finas banhadas a ouro 18k.
STORE_SLOGAN=Brilhe em cada momento
STORE_LOGO_PATH=images/logo.png
STORE_EMAIL=contato@vjsemijoias.com
STORE_PHONE=(51) 98211-0842
STORE_WHATSAPP=51 982110842
STORE_INSTAGRAM=vj_semijoias
STORE_WEBSITE=www.vjsemijoias.com
STORE_CNPJ=
STORE_CATALOG_TITLE=CATALOGO VJ SEMIJOIAS
STORE_CATALOG_COLLECTION=Colecao Banhada a Ouro 18k
STORE_CATALOG_FILENAME=catalogo-vj-semijoias.pdf

# Frete por ambiente:
# free = frete gratis; fixed = valor fixo; threshold = gratis acima de um valor minimo
SHIPPING_MODE=free
SHIPPING_FIXED_VALUE=0
SHIPPING_FREE_MINIMUM=0
SHIPPING_ESTIMATED_DAYS=5-10

# Provider externo de frete (padrao/fallback; ajustes operacionais podem ser feitos no admin):
# internal = usa as regras acima; melhor_envio = tenta Melhor Envio e faz fallback para internal.
SHIPPING_PROVIDER=internal
MELHOR_ENVIO_API_BASE=https://www.melhorenvio.com.br/api/v2
# MELHOR_ENVIO_TOKEN=  # mantenha no ambiente; nao vai para o admin
# MELHOR_ENVIO_FROM_POSTAL_CODE=01001000
# MELHOR_ENVIO_SERVICES=1,2
# Correios,Jadlog,Loggi,J&T,Buslog,LATAM Cargo
MELHOR_ENVIO_ALLOWED_COMPANY_IDS=1,2,14,15,12,6
MELHOR_ENVIO_TIMEOUT_SECONDS=6

# Descontos por ambiente:
COUPONS_ENABLED=true
COUPON_CODE=VJ10
COUPON_DISCOUNT_PERCENT=10
COUPON_USAGE_LIMIT=100
